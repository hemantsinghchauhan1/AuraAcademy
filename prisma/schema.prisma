datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id        String    @id @default(uuid())
  clerkId   String?   @unique   // Clerk user ID (null for legacy JWT users)
  email     String    @unique
  password  String?   // Hashed — optional (Clerk users have no local password)
  role      Role      @default(STUDENT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  profile   Profile?
  attempts  Attempt[]
  analytics Analytics?
  posts     Post[]    // Forum relations
  comments  Comment[]
  votes     Vote[]

  @@index([email])
  @@index([clerkId])
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  avatarUrl String?
  streak    Int      @default(0)
  xp        Int      @default(0)
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subject {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String
  icon        String
  quizzes     Quiz[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quiz {
  id             String     @id @default(uuid())
  title          String
  description    String
  subjectId      String
  subject        Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  timeLimit      Int?       // In minutes
  totalQuestions Int
  difficulty     Difficulty @default(MEDIUM)
  questions      Question[]
  attempts       Attempt[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([subjectId])
}

model Question {
  id            String   @id @default(uuid())
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionText  String
  options       Option[] // Upgraded relational Option model
  correctAnswer String   // Must correspond to the label of one of the Options (e.g. "A", "B", "C", "D")
  explanation   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([quizId])
}

model Option {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String   // "A", "B", "C", "D"
  text       String   // Option text choice
  createdAt  DateTime @default(now())

  @@index([questionId])
}

model Attempt {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score          Int
  totalQuestions Int
  timeSpent      Int      // In seconds
  answers        String   // JSON string of user answers {questionId: chosenLabel}
  completedAt    DateTime @default(now())

  @@index([userId])
  @@index([quizId])
}

model Analytics {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weakTopics        String   // JSON string of weak topics with accuracy metrics
  overallAccuracy   Float    @default(0.0)
  totalQuizzesTaken Int      @default(0)
  updatedAt         DateTime @updatedAt
}

model Leaderboard {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String
  xp        Int      @default(0)
  streak    Int      @default(0)
  rank      Int
  updatedAt DateTime @updatedAt

  @@index([xp(sort: Desc)])
}

// --- FORUMS & PEER COMMUNITIES MODELS ---

model Community {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique // e.g. "quantum-math"
  description String
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model Post {
  id          String    @id @default(uuid())
  title       String
  content     String    // Markdown text body
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  upvotes     Int       @default(0)
  comments    Comment[]
  votes       Vote[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([communityId])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String   // Comment text content
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
}

model Vote {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  value     Int      // 1 for Upvote, -1 for Downvote
  createdAt DateTime @default(now())

  @@unique([userId, postId]) // Compound unique key to prevent double-voting!
  @@index([postId])
}
