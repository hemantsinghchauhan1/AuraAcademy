datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  MODERATOR
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id              String                 @id @default(uuid())
  clerkId         String?                @unique   // Clerk user ID (null for legacy JWT users)
  email           String                 @unique
  password        String?                // Hashed — optional (Clerk users have no local password)
  role            Role                   @default(STUDENT)
  isSuspended     Boolean                @default(false) // Suspended/banned flag
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  profile         Profile?
  attempts        Attempt[]
  analytics       Analytics?
  posts           Post[]                 // Forum relations
  comments        Comment[]
  votes           Vote[]
  reportsCreated  Report[]               @relation("Reporter")
  moderatorLogs   ModerationLog[]        @relation("ModeratorRelation")
  adminActions    AdminAction[]          @relation("AdminRelation")
  uploadedFiles   UploadedFile[]
  
  // LMS relations
  enrollments          Enrollment[]
  lessonProgress       LessonProgress[]
  submissions          AssignmentSubmission[] @relation("StudentSubmissions")
  gradedSubmissions    AssignmentSubmission[] @relation("GradedBySubmissions")
  courseReviews        CourseReview[]

  @@index([email])
  @@index([clerkId])
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  avatarUrl String?
  streak    Int      @default(0)
  xp        Int      @default(0)
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subject {
  id            String         @id @default(uuid())
  name          String         @unique
  slug          String         @unique
  description   String
  icon          String
  quizzes       Quiz[]
  uploadedFiles UploadedFile[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Quiz {
  id             String     @id @default(uuid())
  title          String
  description    String
  subjectId      String
  subject        Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  timeLimit      Int?       // In minutes
  totalQuestions Int
  difficulty     Difficulty @default(MEDIUM)
  questions      Question[]
  attempts       Attempt[]
  lessons        Lesson[]   // Linked LMS lessons
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([subjectId])
}

model Question {
  id            String   @id @default(uuid())
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionText  String
  options       Option[] // Relational Option model
  correctAnswer String   // Must correspond to the label of one of the Options (e.g. "A", "B", "C", "D")
  explanation   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([quizId])
}

model Option {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String   // "A", "B", "C", "D"
  text       String   // Option text choice
  createdAt  DateTime @default(now())

  @@index([questionId])
}

model Attempt {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score          Int
  totalQuestions Int
  timeSpent      Int      // In seconds
  answers        String   // JSON string of user answers {questionId: chosenLabel}
  completedAt    DateTime @default(now())

  @@index([userId])
  @@index([quizId])
}

model Analytics {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weakTopics        String   // JSON string of weak topics with accuracy metrics
  overallAccuracy   Float    @default(0.0)
  totalQuizzesTaken Int      @default(0)
  updatedAt         DateTime @updatedAt
}

model Leaderboard {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String
  xp        Int      @default(0)
  streak    Int      @default(0)
  rank      Int
  updatedAt DateTime @updatedAt

  @@index([xp(sort: Desc)])
}

// --- FORUMS & PEER COMMUNITIES MODELS ---

model Community {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique // e.g. "quantum-math"
  description String
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model Post {
  id          String    @id @default(uuid())
  title       String
  content     String    // Markdown text body
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  upvotes     Int       @default(0)
  comments    Comment[]
  votes       Vote[]
  reports     Report[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([communityId])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String   // Comment text content
  reports   Report[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
}

model Vote {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  value     Int      // 1 for Upvote, -1 for Downvote
  createdAt DateTime @default(now())

  @@unique([userId, postId]) // Compound unique key to prevent double-voting!
  @@index([postId])
}

// --- PHASE 6: MODERATION & CMS MODELS ---

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  OFF_TOPIC
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model Report {
  id          String       @id @default(uuid())
  reason      ReportReason
  details     String?      // Optional details
  status      ReportStatus @default(PENDING)
  
  // Target relations (reported post or reported comment)
  postId      String?
  post        Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId   String?
  comment     Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  // Reporter relation
  reporterId  String
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([reporterId])
  @@index([postId])
  @@index([commentId])
}

enum ModerationAction {
  REMOVE_POST
  REMOVE_COMMENT
  SUSPEND_USER
  UNSUSPEND_USER
  RESOLVE_REPORT
}

model ModerationLog {
  id          String           @id @default(uuid())
  action      ModerationAction
  moderatorId String
  moderator   User             @relation("ModeratorRelation", fields: [moderatorId], references: [id], onDelete: Cascade)
  targetId    String           // ID of the user, post, or comment that was acted on
  reason      String
  createdAt   DateTime         @default(now())

  @@index([moderatorId])
  @@index([action])
}

enum AdminActionType {
  CREATE_QUIZ
  EDIT_QUIZ
  DELETE_QUIZ
  CREATE_SUBJECT
  UPDATE_ROLE
}

model AdminAction {
  id        String          @id @default(uuid())
  action    AdminActionType
  adminId   String
  admin     User            @relation("AdminRelation", fields: [adminId], references: [id], onDelete: Cascade)
  details   String          // Summary of the admin action
  createdAt DateTime        @default(now())

  @@index([adminId])
}

model UploadedFile {
  id           String        @id @default(uuid())
  name         String
  url          String
  key          String
  size         Int
  mimeType     String
  
  // Category relation
  categoryId   String
  category     PaperCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  // Tags
  semester     Int?
  subjectId    String?
  subject      Subject?      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  // Uploader relation
  uploadedById String
  uploadedBy   User          @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([categoryId])
  @@index([subjectId])
  @@index([uploadedById])
}

model PaperCategory {
  id          String         @id @default(uuid())
  name        String         @unique
  slug        String         @unique
  description String?
  files       UploadedFile[]
  createdAt   DateTime       @default(now())
}

// --- PHASE 7: Structured Course Learning System Models ---

model Course {
  id           String         @id @default(uuid())
  title        String
  slug         String         @unique
  description  String
  thumbnailUrl String?
  isPublished  Boolean        @default(false)
  isPremium    Boolean        @default(false)
  
  // Relations
  modules      Module[]
  enrollments  Enrollment[]
  reviews      CourseReview[]
  
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Module {
  id          String   @id @default(uuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  order       Int
  
  lessons     Lesson[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId])
}

enum VideoType {
  YOUTUBE
  LOOM
  URL
}

model Lesson {
  id           String           @id @default(uuid())
  moduleId     String
  module       Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title        String
  content      String           // Markdown text body
  
  // Video fields
  videoUrl     String?
  videoType    VideoType?
  order        Int
  
  // Quiz Connection (Optional)
  quizId       String?
  quiz         Quiz?            @relation(fields: [quizId], references: [id], onDelete: SetNull)
  
  // Relations
  resources    Resource[]
  progress     LessonProgress[]
  assignments  Assignment[]
  
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([moduleId])
}

model Resource {
  id        String   @id @default(uuid())
  name      String
  url       String
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([lessonId])
}

model Enrollment {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed Boolean  @default(false)
  watchTime Int      @default(0) // watched seconds
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Assignment {
  id          String                 @id @default(uuid())
  title       String
  description String                 // Instructions Markdown
  lessonId    String
  lesson      Lesson                 @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  dueDate     DateTime?
  submissions AssignmentSubmission[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([lessonId])
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model AssignmentSubmission {
  id           String           @id @default(uuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User             @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  
  fileUrl      String           // Uploaded PDF or image base64
  comment      String?
  status       SubmissionStatus @default(PENDING)
  
  feedback     String?
  gradedById   String?
  gradedBy     User?            @relation("GradedBySubmissions", fields: [gradedById], references: [id], onDelete: SetNull)
  
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([assignmentId])
  @@index([studentId])
}

model CourseReview {
  id        String   @id @default(uuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
}

