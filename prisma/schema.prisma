datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  MODERATOR
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id              String                 @id @default(uuid())
  clerkId         String?                @unique   // Clerk user ID (null for legacy JWT users)
  email           String                 @unique
  password        String?                // Hashed — optional (Clerk users have no local password)
  role            Role                   @default(STUDENT)
  isSuspended     Boolean                @default(false) // Suspended/banned flag
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  profile         Profile?
  attempts        Attempt[]
  analytics       Analytics?
  posts           Post[]                 // Forum relations
  comments        Comment[]
  votes           Vote[]
  reportsCreated  Report[]               @relation("Reporter")
  moderatorLogs   ModerationLog[]        @relation("ModeratorRelation")
  adminActions    AdminAction[]          @relation("AdminRelation")
  uploadedFiles   UploadedFile[]
  
  // LMS relations
  enrollments          Enrollment[]
  lessonProgress       LessonProgress[]
  submissions          AssignmentSubmission[] @relation("StudentSubmissions")
  gradedSubmissions    AssignmentSubmission[] @relation("GradedBySubmissions")
  courseReviews        CourseReview[]
  
  // Gamification relations
  xpLogs               XPLog[]
  userAchievements     UserAchievement[]
  userBadges           UserBadge[]
  userMissions         UserMission[]
  certificates         Certificate[]
  conversationParticipations ConversationParticipant[]
  sentMessages               Message[]
  ownedConversations         Conversation[]         @relation("ConversationOwner")
  pollVotes                  RoomPollVote[]
  notifications              Notification[]
  notificationPreference     NotificationPreference?
  aiConversations            AiConversation[]
  aiRecommendations          AiRecommendation[]
  ingestionJobs              IngestionJob[]

  // Onboarding & IITM fields
  username             String?                @unique
  bio                  String?
  profileVisibility    Boolean                @default(true)
  rollNumber           String?
  degreeTrack          DegreeTrack?
  isOfficialIITM       Boolean                @default(false)
  onboardingCompleted  Boolean                @default(false)
  selectedSubjects     UserSelectedSubject[]

  @@index([email])
  @@index([clerkId])
  @@index([username])
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  avatarUrl String?
  streak    Int      @default(0)
  xp        Int      @default(0)
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subject {
  id            String                @id @default(uuid())
  code          String?               @unique // e.g. "BSCS2002"
  name          String                @unique
  slug          String                @unique
  description   String
  icon          String
  track         DegreeTrack?
  level         String?               // e.g. "FOUNDATION", "DIPLOMA", "DEGREE", "ELECTIVES"
  quizzes        Quiz[]
  uploadedFiles  UploadedFile[]
  ingestionJobs  IngestionJob[]
  usersSelected  UserSelectedSubject[]
  academicEvents AcademicEvent[]
  studyRooms     Conversation[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model Quiz {
  id             String     @id @default(uuid())
  title          String
  description    String
  subjectId      String
  subject        Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  timeLimit      Int?       // In minutes
  totalQuestions Int
  difficulty     Difficulty @default(MEDIUM)
  questions      Question[]
  attempts       Attempt[]
  lessons        Lesson[]   // Linked LMS lessons
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([subjectId])
}

model Question {
  id            String   @id @default(uuid())
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionText  String
  options       Option[] // Relational Option model
  correctAnswer String   // Must correspond to the label of one of the Options (e.g. "A", "B", "C", "D")
  explanation   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([quizId])
}

model Option {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String   // "A", "B", "C", "D"
  text       String   // Option text choice
  createdAt  DateTime @default(now())

  @@index([questionId])
}

model Attempt {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score          Int
  totalQuestions Int
  timeSpent      Int      // In seconds
  answers        String   // JSON string of user answers {questionId: chosenLabel}
  completedAt    DateTime @default(now())

  @@index([userId])
  @@index([quizId])
}

model Analytics {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weakTopics        String   // JSON string of weak topics with accuracy metrics
  overallAccuracy   Float    @default(0.0)
  totalQuizzesTaken Int      @default(0)
  updatedAt         DateTime @updatedAt
}

model Leaderboard {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String
  xp        Int      @default(0)
  streak    Int      @default(0)
  rank      Int
  updatedAt DateTime @updatedAt

  @@index([xp(sort: Desc)])
}

// --- FORUMS & PEER COMMUNITIES MODELS ---

model Community {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique // e.g. "quantum-math"
  description String
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model Post {
  id          String    @id @default(uuid())
  title       String
  content     String    // Markdown text body
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  upvotes     Int       @default(0)
  comments    Comment[]
  votes       Vote[]
  reports     Report[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([communityId])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String   // Comment text content
  reports   Report[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
}

model Vote {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  value     Int      // 1 for Upvote, -1 for Downvote
  createdAt DateTime @default(now())

  @@unique([userId, postId]) // Compound unique key to prevent double-voting!
  @@index([postId])
}

// --- PHASE 6: MODERATION & CMS MODELS ---

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  OFF_TOPIC
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model Report {
  id          String       @id @default(uuid())
  reason      ReportReason
  details     String?      // Optional details
  status      ReportStatus @default(PENDING)
  
  // Target relations (reported post or reported comment)
  postId      String?
  post        Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId   String?
  comment     Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  // Reporter relation
  reporterId  String
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([reporterId])
  @@index([postId])
  @@index([commentId])
}

enum ModerationAction {
  REMOVE_POST
  REMOVE_COMMENT
  SUSPEND_USER
  UNSUSPEND_USER
  RESOLVE_REPORT
}

model ModerationLog {
  id          String           @id @default(uuid())
  action      ModerationAction
  moderatorId String
  moderator   User             @relation("ModeratorRelation", fields: [moderatorId], references: [id], onDelete: Cascade)
  targetId    String           // ID of the user, post, or comment that was acted on
  reason      String
  createdAt   DateTime         @default(now())

  @@index([moderatorId])
  @@index([action])
}

enum AdminActionType {
  CREATE_QUIZ
  EDIT_QUIZ
  DELETE_QUIZ
  CREATE_SUBJECT
  UPDATE_ROLE
}

model AdminAction {
  id        String          @id @default(uuid())
  action    AdminActionType
  adminId   String
  admin     User            @relation("AdminRelation", fields: [adminId], references: [id], onDelete: Cascade)
  details   String          // Summary of the admin action
  createdAt DateTime        @default(now())

  @@index([adminId])
}

model UploadedFile {
  id           String        @id @default(uuid())
  name         String
  url          String
  key          String
  size         Int
  mimeType     String
  
  // Category relation
  categoryId   String
  category     PaperCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  // Tags
  semester     Int?
  subjectId    String?
  subject      Subject?      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  // Uploader relation
  uploadedById String
  uploadedBy   User          @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([categoryId])
  @@index([subjectId])
  @@index([uploadedById])
}

model PaperCategory {
  id          String         @id @default(uuid())
  name        String         @unique
  slug        String         @unique
  description String?
  files       UploadedFile[]
  createdAt   DateTime       @default(now())
}

// --- PHASE 7: Structured Course Learning System Models ---

model Course {
  id           String         @id @default(uuid())
  title        String
  slug         String         @unique
  description  String
  thumbnailUrl String?
  isPublished  Boolean        @default(false)
  isPremium    Boolean        @default(false)
  
  // Relations
  modules      Module[]
  enrollments  Enrollment[]
  reviews      CourseReview[]
  certificates Certificate[]
  
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Module {
  id          String   @id @default(uuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  order       Int
  
  lessons     Lesson[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId])
}

enum VideoType {
  YOUTUBE
  LOOM
  URL
}

model Lesson {
  id           String           @id @default(uuid())
  moduleId     String
  module       Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title        String
  content      String           // Markdown text body
  
  // Video fields
  videoUrl     String?
  videoType    VideoType?
  order        Int
  
  // Quiz Connection (Optional)
  quizId       String?
  quiz         Quiz?            @relation(fields: [quizId], references: [id], onDelete: SetNull)
  
  // Relations
  resources    Resource[]
  progress     LessonProgress[]
  assignments  Assignment[]
  
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([moduleId])
}

model Resource {
  id        String   @id @default(uuid())
  name      String
  url       String
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([lessonId])
}

model Enrollment {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed Boolean  @default(false)
  watchTime Int      @default(0) // watched seconds
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Assignment {
  id          String                 @id @default(uuid())
  title       String
  description String                 // Instructions Markdown
  lessonId    String
  lesson      Lesson                 @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  dueDate     DateTime?
  submissions AssignmentSubmission[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([lessonId])
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model AssignmentSubmission {
  id           String           @id @default(uuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User             @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  
  fileUrl      String           // Uploaded PDF or image base64
  comment      String?
  status       SubmissionStatus @default(PENDING)
  
  feedback     String?
  gradedById   String?
  gradedBy     User?            @relation("GradedBySubmissions", fields: [gradedById], references: [id], onDelete: SetNull)
  
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([assignmentId])
  @@index([studentId])
}

model CourseReview {
  id        String   @id @default(uuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([courseId])
}

// --- PHASE 8: Gamification & Certification System Models ---

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

model Achievement {
  id               String            @id @default(uuid())
  title            String            @unique
  description      String
  icon             String            // Emoji representation
  xpReward         Int               @default(100)
  rarity           Rarity            @default(COMMON)
  
  userAchievements UserAchievement[]
  
  createdAt        DateTime          @default(now())
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String
  icon        String      // Emoji representation
  
  userBadges  UserBadge[]
  
  createdAt   DateTime    @default(now())
}

model UserBadge {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId    String
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

enum MissionType {
  LESSON
  QUIZ
  FORUM
  STREAK
}

model Mission {
  id           String        @id @default(uuid())
  title        String
  description  String
  xpReward     Int           @default(50)
  targetCount  Int           @default(1)
  type         MissionType
  
  userMissions UserMission[]
  
  createdAt    DateTime      @default(now())
}

model UserMission {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionId    String
  mission      Mission     @relation(fields: [missionId], references: [id], onDelete: Cascade)
  
  currentCount Int         @default(0)
  completed    Boolean     @default(false)
  claimed      Boolean     @default(false)
  
  updatedAt    DateTime    @updatedAt

  @@unique([userId, missionId])
  @@index([userId])
  @@index([missionId])
}

model Certificate {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  certificateCode String   @unique // verification ID code
  issuedAt        DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model XPLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String   // e.g. "COMPLETED_LESSON", "SOLVED_QUIZ"
  createdAt DateTime @default(now())

  @@index([userId])
}

model LevelSystem {
  id          String   @id @default(uuid())
  level       Int      @unique
  xpThreshold Int      // XP threshold required to reach level
  title       String   // e.g. "DSA Initiate", "Algorithm Overlord"
  createdAt   DateTime @default(now())
}

enum DegreeTrack {
  BS_DATA_SCIENCE
  BS_ELECTRONIC_SYSTEMS
}

model UserSelectedSubject {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  selectedAt DateTime @default(now())

  @@unique([userId, subjectId])
  @@index([userId])
  @@index([subjectId])
}

enum EventType {
  LIVE_CLASS
  ASSIGNMENT
  QUIZ
  EXAM
  NOTICE
}

model AcademicEvent {
  id          String   @id @default(uuid())
  title       String
  description String
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  startTime   DateTime
  endTime     DateTime
  eventType   EventType
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  createdAt   DateTime @default(now())

  @@index([subjectId])
  @@index([startTime])
}

// ── EXTENSIBLE REALTIME CHAT & STUDY ROOM MODELS ──────────────

enum RoomType {
  SUBJECT
  PROJECT
  COMMUNITY
  PRIVATE_GROUP
}

enum ParticipantRole {
  MEMBER
  MODERATOR
  OWNER
}

model Conversation {
  id              String                    @id @default(uuid())
  isGroup         Boolean                   @default(false)
  name            String?                   // Optional group chat/study room name
  
  // Study Room metadata extensions
  roomDescription String?
  roomType        RoomType?                 @default(PRIVATE_GROUP)
  roomAvatar      String?
  ownerId         String?
  owner           User?                     @relation("ConversationOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  subjectId       String?
  subject         Subject?                  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  participants    ConversationParticipant[]
  messages        Message[]
  pinnedResources PinnedResource[]
  polls           RoomPoll[]
  sessions        StudySession[]
  aiSummary       AiSummary?
  
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([updatedAt(sort: Desc)])
}

model ConversationParticipant {
  id             String          @id @default(uuid())
  conversationId String
  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           ParticipantRole @default(MEMBER)
  joinedAt       DateTime        @default(now())

  @@unique([conversationId, userId]) // User can only join a conversation once!
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String       // Message body
  seen           Boolean      @default(false) // Unread badge tracker
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

model PinnedResource {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  title          String
  url            String?
  description    String?
  type           String       // e.g. "PYQ", "NOTE", "LINK", "ANNOUNCEMENT"
  createdById    String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model RoomPoll {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  question       String
  options        String       // JSON array of strings
  votes          RoomPollVote[]
  createdById    String
  createdAt      DateTime     @default(now())
  expiresAt      DateTime?

  @@index([conversationId])
}

model RoomPollVote {
  id          String   @id @default(uuid())
  pollId      String
  poll        RoomPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  optionIndex Int
  createdAt   DateTime @default(now())

  @@unique([pollId, userId])
}

model StudySession {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  createdById    String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

// ── UNIFIED CAMPUS NOTIFICATION & ACTIVITY SYSTEM MODELS ──

enum NotificationType {
  DIRECT_MESSAGE
  ROOM_MESSAGE
  ROOM_MENTION
  ASSIGNMENT_DEADLINE
  QUIZ_REMINDER
  STUDY_SESSION
  POLL_CREATED
  ACHIEVEMENT_UNLOCK
  LEADERBOARD_UPDATE
  SYSTEM_NOTICE
}

enum NotificationPriority {
  CRITICAL
  IMPORTANT
  NORMAL
  SOCIAL
}

model Notification {
  id          String               @id @default(uuid())
  userId      String
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  description String
  link        String?              // Redirection target link (e.g. "/rooms/[id]" or "/quiz/[id]")
  read        Boolean              @default(false)
  priority    NotificationPriority @default(NORMAL)
  metadata    String?              // JSON string for extra contextual metadata
  createdAt   DateTime             @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model NotificationPreference {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  muteDMs                Boolean  @default(false)
  muteRoomMessages       Boolean  @default(false)
  muteSocialAlerts       Boolean  @default(false)
  muteLeaderboardUpdates Boolean  @default(false)
  muteReminders          Boolean  @default(false)
  mutedRoomIds           String   @default("[]") // JSON array of muted room IDs
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model AiConversation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  messages  String   // JSON string of conversation: { role: "user" | "assistant", content: string, createdAt: string }[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AiRecommendation {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "QUIZ" | "SESSION" | "PYQ" | "ROOM"
  title       String
  description String
  itemId      String?  // Optional target relation key (e.g. quizId, roomId)
  reason      String   // Why recommended
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model AiSummary {
  id             String       @id @default(uuid())
  conversationId String       @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  content        String       // Summary markdown text
  keyTakeaways   String       // JSON string of string[] takeaways
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model AiCache {
  id         String   @id @default(uuid())
  promptHash String   @unique
  response   String
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([promptHash])
}

enum IngestionStatus {
  PENDING
  PARSING
  EXTRACTING
  CLASSIFYING
  DRAFT
  PUBLISHED
  FAILED
}

model IngestionJob {
  id              String          @id @default(uuid())
  fileName        String
  fileUrl         String
  fileKey         String
  fileSize        Int
  mimeType        String
  status          IngestionStatus @default(PENDING)
  error           String?         @db.Text
  extractedText   String?         @db.Text
  parsingStages   String?         @db.Text // JSON string: list of { stage: string, status: string, timestamp: string }
  retryCount      Int             @default(0)
  
  // Detection metadata
  detectedTrack   DegreeTrack?
  detectedSubject String?
  detectedLevel   String?
  
  // Relations
  subjectId       String?
  subject         Subject?        @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  uploadedById    String
  uploadedBy      User            @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  
  // Draft quiz payload
  draftQuizTitle  String?
  draftQuizDesc   String?
  draftQuestions  String?         @db.Text // JSON string: array of questions: { questionText: string, options: { label: string, text: string }[], correctAnswer: string, explanation: string, difficulty: string, tags: string[] }
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([subjectId])
  @@index([uploadedById])
}


