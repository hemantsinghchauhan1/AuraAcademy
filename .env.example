# ==============================================================
# AuraAcademy — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ==============================================================

# --- DATABASE CONFIGURATION ---
# Supabase PostgreSQL — Connection Pooler URL (for runtime queries via pgbouncer)
DATABASE_URL="postgresql://username:password@host:6543/database?pgbouncer=true"

# Supabase PostgreSQL — Direct connection URL (for Prisma migrate/db push)
DIRECT_URL="postgresql://username:password@host:5432/database"

# --- SECURITY ---
# High-entropy JWT secret. Generate with: openssl rand -base64 64
JWT_SECRET="generate-a-secure-random-64-character-string-here"

# --- APP URL ---
# Full public URL of your deployment (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- GOOGLE OAUTH (Optional — required for real Google Sign-In) ---
# Get from: https://console.cloud.google.com/apis/credentials
# Set Authorized Redirect URI to: $NEXT_PUBLIC_APP_URL/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- NODE RUNTIME ---
NODE_ENV="development"
