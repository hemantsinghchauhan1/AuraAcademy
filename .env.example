# DATABASE CONFIGURATION
# For local SQLite database (default for quick offline testing):
DATABASE_URL="file:./dev.db"

# For production cloud databases (PostgreSQL, Neon, Supabase):
# DATABASE_URL="postgresql://username:password@hostname:port/database?sslmode=require"

# SECURITY CONFIGURATION
# High-entropy secret key used for signing and verifying stateless session JWT cookies:
JWT_SECRET="generate-a-secure-random-64-character-string-here"

# NODE RUNTIME SETTINGS
# Set to 'production' when deploying to Cloud PaaS services (e.g. Vercel, Railway, Render)
NODE_ENV="development"

# OPTIONAL INTEGRATION KEYS (PHASE 2 FUTURE READY)
# CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
# SUPABASE_ANON_KEY="your-supabase-anon-key"
# SUPABASE_URL="https://your-project-id.supabase.co"
